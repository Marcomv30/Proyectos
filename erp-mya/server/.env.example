# Server local
PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fusion / integraciones
EMPRESA_ID=1
POLL_INTERVAL_MS=15000
FUSION_API_URL=
FUSION_SSH_HOST=
FUSION_SSH_PORT=22
FUSION_SSH_USER=
FUSION_SSH_PASS=
FUSION_PG_DB=
FUSION_PG_USER=
FUSION_PG_PASSWORD=
FUSION_TUNNEL_PORT=15432
FUSION_CANT=200

# Correo / archivos
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=consumers
COMPROBANTES_DIR=C:/MYA/comprobantes
ENCRYPT_KEY=
RESEND_API_KEY=
SMTP_FROM=

# Deploy frontend desde Superusuario
FRONTEND_DEPLOY_SOURCE_DIR=
FRONTEND_DEPLOY_PUBLISH_DIR=/home/mya-frontend
FRONTEND_DEPLOY_BACKUP_DIR=/home/frontend-backups
FRONTEND_SYNC_CMD=
# Ejemplo local Windows:
# FRONTEND_SYNC_CMD=powershell -ExecutionPolicy Bypass -File .\scripts\sync-frontend-to-vps.ps1
FRONTEND_DEPLOY_INSTALL_CMD=
FRONTEND_DEPLOY_BUILD_CMD=npm run build
FRONTEND_DEPLOY_BUILD_SUBDIR=build
VPS_FILE_SYNC_FRONTEND_DIR=/home/mya-frontend-src
VPS_FILE_SYNC_BACKEND_DIR=/home/mya-backend
VPS_FILE_SYNC_MISC_DIR=/root
