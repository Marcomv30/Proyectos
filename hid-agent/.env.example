# ── Servidor MYA central ──────────────────────────────────
API_URL=http://192.168.1.100:3001
AGENT_SECRET=cambiar_por_clave_segura
EMPRESA_ID=4
PISTA=1

# ── Modo de operación ─────────────────────────────────────
# stdin  = lector teclado USB (pruebas, una sola bomba)
# serial = lectores USB-serial CH340/CP2102 (producción, dos bombas)
MODO=stdin

# ── Modo stdin: una bomba ─────────────────────────────────
PUMP_A_ID=1

# ── Modo serial: dos bombas ───────────────────────────────
# Verificar puerto en Administrador de dispositivos > Puertos COM
# PUMP_A_PORT=COM3
# PUMP_A_ID=1
# PUMP_B_PORT=COM4
# PUMP_B_ID=2
# SERIAL_BAUD=9600
